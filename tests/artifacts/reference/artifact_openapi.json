{
  "openapi": "3.1.0",
  "info": {
    "title": "Open Notebook API",
    "description": "API for Open Notebook - Research Assistant",
    "version": "0.1.0"
  },
  "paths": {
    "/api/artifacts/types": {
      "get": {
        "tags": [
          "artifacts"
        ],
        "summary": "List Types",
        "description": "Return the registered artifact types and their descriptions.",
        "operationId": "list_types_api_artifacts_types_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response List Types Api Artifacts Types Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/artifacts/generate": {
      "post": {
        "tags": [
          "artifacts"
        ],
        "summary": "Generate",
        "description": "Submit an artifact-generation job to the surreal-commands queue.\n\nThe job runs asynchronously; poll GET /artifacts/jobs/{job_id}.",
        "operationId": "generate_api_artifacts_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArtifactGenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactJobSubmitted"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/artifacts/jobs/{job_id}": {
      "get": {
        "tags": [
          "artifacts"
        ],
        "summary": "Get Job",
        "description": "Return the current status + payload of an artifact generation job.",
        "operationId": "get_job_api_artifacts_jobs__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactJobResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/artifacts/download": {
      "get": {
        "tags": [
          "artifacts"
        ],
        "summary": "Download",
        "description": "Return a generated artifact file.\n\nPath-traversal guarded: the resolved path must sit inside\n``ARTIFACT_OUTPUT_ROOT`` (see ``open_notebook/config.py``).",
        "operationId": "download_api_artifacts_download_get",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Path"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ArtifactFileOut": {
        "properties": {
          "path": {
            "type": "string",
            "title": "Path"
          },
          "mime_type": {
            "type": "string",
            "title": "Mime Type"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          }
        },
        "type": "object",
        "required": [
          "path",
          "mime_type"
        ],
        "title": "ArtifactFileOut"
      },
      "ArtifactGenerateRequest": {
        "properties": {
          "artifact_type": {
            "type": "string",
            "title": "Artifact Type",
            "description": "e.g. 'briefing', 'slide_deck'"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/ArtifactSourceIn"
            },
            "type": "array",
            "title": "Sources"
          },
          "notebook_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notebook Id"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config"
          },
          "model_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Id"
          },
          "output_dir": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output Dir"
          }
        },
        "type": "object",
        "required": [
          "artifact_type"
        ],
        "title": "ArtifactGenerateRequest"
      },
      "ArtifactJobResult": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "artifact_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Artifact Type"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Summary"
          },
          "structured": {
            "additionalProperties": true,
            "type": "object",
            "title": "Structured"
          },
          "files": {
            "items": {
              "$ref": "#/components/schemas/ArtifactFileOut"
            },
            "type": "array",
            "title": "Files"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          },
          "provenance": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Provenance"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "generated_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Generated At"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "ArtifactJobResult",
        "description": "Shape returned by GET /artifacts/jobs/{id} when complete."
      },
      "ArtifactJobSubmitted": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": "submitted"
          }
        },
        "type": "object",
        "required": [
          "job_id"
        ],
        "title": "ArtifactJobSubmitted"
      },
      "ArtifactSourceIn": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title",
            "description": "Source title or identifier"
          },
          "content": {
            "type": "string",
            "title": "Content",
            "description": "Raw text content"
          },
          "url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Url"
          },
          "author": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Author"
          },
          "published_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Published At"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "title",
          "content"
        ],
        "title": "ArtifactSourceIn"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
